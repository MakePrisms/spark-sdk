{
    "name": "@agicash/breez-sdk-spark",
    "version": "0.1.0",
    "description": "Fork of Breez Spark SDK with support for delegated Lightning invoices",
    "repository": "https://github.com/MakePrisms/spark-sdk",
    "author": "Agicash (https://github.com/MakePrisms)",
    "license": "MIT",
    "bugs": {
      "url": "https://github.com/MakePrisms/spark-sdk/issues"
    },
    "files": [
      "bundler",
      "deno",
      "nodejs",
      "web",
      "ssr",
      "!examples"
    ],
    "exports": {
      "./bundler": "./bundler/index.js",
      "./deno": "./deno/breez_sdk_spark_wasm.js",
      "./nodejs": "./nodejs/index.js",
      "./web": "./web/index.js",
      "./web/wasm": "./web/breez_sdk_spark_wasm_bg.wasm",
      "./ssr": "./ssr/index.js",
      ".": {
        "node": {
          "import": "./nodejs/index.mjs",
          "require": "./nodejs/index.js"
        },
        "deno": "./deno/breez_sdk_spark_wasm.js",
        "default": "./web/index.js"
      }
    },
    "publishConfig": {
      "registry": "https://registry.npmjs.org/"
    },
    "engines": {
      "node": ">=22"
    },
    "optionalDependencies": {
      "better-sqlite3": "^12.2.0",
      "pg": "^8.18.0"
    }
  }